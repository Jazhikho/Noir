    typingSpeed: 0
    nextLineIndex: 0
    onLineStart:
      m_PersistentCalls:
        m_Calls: []
    onLineEnd:
      m_PersistentCalls:
        m_Calls: []
    choices: []
  - speaker: 0
    text: It seems I am actually looking through you, funnily enough.
    portrait: {fileID: 0}
    typingSpeed: 0
    nextLineIndex: 0
    onLineStart:
      m_PersistentCalls:
        m_Calls: []
    onLineEnd:
      m_PersistentCalls:
        m_Calls: []
    choices: []
  - speaker: 1
    text: "Oh. No- no you\u2019re right. Sometimes I forget people can\u2019t see
      me. Sorry."
    portrait: {fileID: 0}
    typingSpeed: 0
    nextLineIndex: 0
    onLineStart:
      m_PersistentCalls:
        m_Calls: []
    onLineEnd:
      m_PersistentCalls:
        m_Calls: []
    choices: []
  - speaker: 0
    text: "No offense taken, I\u2019m sure we\u2019ve both got bigger things to worry
      about."
